{
  "name": "finance-data-processing-and-access-control",
  "version": "1.0.0",
  "description": "Backend for a finance dashboard system where different users interact with financial records based on their role.",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "dev": "tsx watch src/app.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "NODE_ENV=test DOTENV_CONFIG_PATH=.env.test node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "NODE_ENV=test DOTENV_CONFIG_PATH=.env.test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "NODE_ENV=test DOTENV_CONFIG_PATH=.env.test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "finance",
    "dashboard",
    "access-control",
    "roles",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-auth": "^1.5.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  }
}
